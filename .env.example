# Start on Sepolia. Mainnet writes will require an explicit network selection.
GWEI_NETWORK=sepolia
GWEI_RPC_URL=

# Never pass a private key on the command line or commit it to Git.
# A keystore/keychain signer will be added after the initial MVP.
GWEI_PRIVATE_KEY=

# Optional override. Defaults to a per-user application data directory.
GWEI_STATE_DIR=

# IPFS publishing adapter configuration.
GWEI_IPFS_PROVIDER=local
GWEI_IPFS_API=http://127.0.0.1:5001
GWEI_IPFS_TOKEN=
