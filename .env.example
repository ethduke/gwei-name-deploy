# Mainnet is the default. Write commands still require --broadcast.
GWEI_NETWORK=mainnet
GWEI_RPC_URL=

# Comma-separated 0xprivatekey:name mappings, for example:
# GWEI_ACCOUNTS=0xabc...:alice.gwei,0xdef...:bob.gwei
GWEI_ACCOUNTS=

# Legacy single signer fallback. Prefer GWEI_ACCOUNTS.
GWEI_PRIVATE_KEY=

# Optional override. Defaults to a per-user application data directory.
GWEI_STATE_DIR=

# IPFS publishing adapter configuration.
GWEI_IPFS_PROVIDER=local
GWEI_IPFS_API=http://127.0.0.1:5001
GWEI_IPFS_TOKEN=
